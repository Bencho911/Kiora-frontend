---
import PanelApp from "../components/panel/PanelApp";
import MainLayout from "@/layouts/mainlayout.astro";
---

<MainLayout title="Panel Principal - Kiora">
  <script is:inline data-astro-rerun>
    function checkAuth() {
      try {
        if (!localStorage.getItem("kiora_token")) {
          window.location.replace("/login/");
        }
      } catch (e) {
        window.location.replace("/login/");
      }
    }
    checkAuth();
    window.addEventListener('pageshow', function (event) {
      if (event.persisted) checkAuth();
    });
    document.addEventListener('astro:page-load', checkAuth);
  </script>
  <PanelApp client:only="react" />
</MainLayout>
