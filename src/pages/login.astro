---
import LoginForm from "../components/auth/LoginForm";
import GlobalControls from "../components/ui/GlobalControls";
import MainLayout from "@/layouts/mainlayout.astro";
---

<MainLayout title="Iniciar Sesión - Kiora">
  <script is:inline data-astro-rerun>
    function checkAuthLogin() {
      try {
        if (localStorage.getItem("kiora_token")) {
          window.location.replace("/panel/");
        }
      } catch (e) {}
    }
    checkAuthLogin();
    window.addEventListener('pageshow', function (event) {
      if (event.persisted) checkAuthLogin();
    });
    document.addEventListener('astro:page-load', checkAuthLogin);
  </script>

  <div class="flex flex-col items-center justify-center min-h-screen w-full relative z-10 px-4"
    style="background: #F5F0EB;"
  >
    <!-- Warm gradient ambient -->
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
      <div class="absolute top-[-15%] right-[-10%] w-[600px] h-[600px] rounded-full"
        style="background: radial-gradient(circle, rgba(236,19,30,0.04) 0%, transparent 70%);"
      />
      <div class="absolute bottom-[-15%] left-[-10%] w-[500px] h-[500px] rounded-full"
        style="background: radial-gradient(circle, rgba(61,26,16,0.05) 0%, transparent 70%);"
      />
    </div>

    <!-- Logo -->
    <div class="relative z-10 mb-8 transition-transform duration-500 hover:scale-105">
      <img
        src="/img/logo-kiora-vectorizado.svg"
        alt="Kiora"
        class="w-44 h-auto object-contain drop-shadow-sm"
      />
    </div>

    <LoginForm client:load />

    <!-- Footer -->
    <footer class="mt-10 mb-8 flex flex-col items-center gap-5 z-50 px-6 w-full max-w-md">
      <div class="h-px w-full" style="background: linear-gradient(to right, transparent, rgba(0,0,0,0.06), transparent);" />
      <div class="flex flex-wrap justify-center items-center gap-x-6 gap-y-3 text-center">
        <a href="/ayuda" class="text-[10px] font-black uppercase tracking-widest" style="color: #9ca3af; transition: color 0.2s;" onmouseover="this.style.color='#ec131e'" onmouseout="this.style.color='#9ca3af'">Ayuda</a>
        <a href="/terminos" class="text-[10px] font-black uppercase tracking-widest" style="color: #9ca3af; transition: color 0.2s;" onmouseover="this.style.color='#6b6b6b'" onmouseout="this.style.color='#9ca3af'">Términos</a>
        <a href="/privacidad" class="text-[10px] font-black uppercase tracking-widest" style="color: #9ca3af; transition: color 0.2s;" onmouseover="this.style.color='#6b6b6b'" onmouseout="this.style.color='#9ca3af'">Privacidad</a>
      </div>
      <p class="text-[9px] font-bold uppercase tracking-[0.2em]" style="color: #c4b8ab;">&copy; {new Date().getFullYear()} Kiora &bull; Smart Kiosk System</p>
    </footer>
  </div>
  <GlobalControls client:load />
</MainLayout>
